<?xml version="1.0" encoding="utf-8" ?>
<layout xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../schema/0.14.0.xsd">
    <styles>
        <button-style id="maybe_btn" background-color="#fff">
            <disabled background-color="#999" text-color="#666"/>
            <hovered background-color="#ddd"/>
        </button-style>
        <container-style id="rounded" border-radius="10" background-color="#ff0" />
    </styles>
    <root>
        <container>
            <row>
                <column width="fill">
                    <container width="200" padding="10" style="rounded">
                        <text width="fill">qweqwewqe</text>
                    </container>
                </column>
                <space width="20"/>
                <column width="fill">
                    <row spacing="10">
                        <button on-press="Message::OnButtonClick">
                            <text>On press</text>
                        </button>
                        <button on-press-with="on_press_with">
                            <text>On press with</text>
                        </button>
                        <button style="maybe_btn" on-press-maybe="on_press_maybe">
                            <text>On press maybe</text>
                        </button>
                        <text>Counter: ${test}</text>
                    </row>
                </column>
            </row>
        </container>
    </root>
</layout>
